# Required: Anthropic API key (or run `ant auth login` instead and omit this)
ANTHROPIC_API_KEY=

# Optional: identify yourself to SEC EDGAR per their fair-use policy
SEC_EDGAR_USER_AGENT="DoughAI research-agent you@example.com"

# Optional overrides
# DOUGHAI_MODEL=claude-opus-4-8
# DOUGHAI_LOG_PATH=data/recommendations.jsonl

# --- Phase 2: web dashboard + digest backend ---

# Required: Supabase Postgres connection string. Use the *transaction pooler*
# URI (port 6543), not the direct connection -- serverless functions open
# many short-lived connections and will exhaust the direct connection limit.
DATABASE_URL=

# Required: Resend API key, used to send the digest email.
RESEND_API_KEY=
# Optional: verified Resend "from" address. Defaults to a resend.dev sender.
# DIGEST_FROM_EMAIL="DoughAI <digest@yourdomain.com>"

# Required: who the daily digest gets sent to.
DIGEST_TO_EMAIL=

# Required: comma-separated tickers for the watchlist + digest, e.g. AAPL,MSFT,NVDA
DIGEST_TICKERS=

# Required in production: shared secret Vercel Cron sends as
# `Authorization: Bearer $CRON_SECRET` when it calls /api/cron/digest. Leave
# unset locally to skip the check.
CRON_SECRET=

# Optional: how long a cached verdict is served before /ticker/{ticker} runs
# the agent again.
# DOUGHAI_CACHE_HOURS=12
